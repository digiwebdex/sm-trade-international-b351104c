# ============================================================
# S. M. Trade International — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smtrade_db
DB_USER=smtrade_user
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD

# ── Backend Server ───────────────────────────────────────────
PORT=4000
API_BASE_URL=https://smtradeint.com
CORS_ORIGIN=https://smtradeint.com

# ── Authentication ───────────────────────────────────────────
JWT_SECRET=GENERATE_A_LONG_RANDOM_STRING_HERE

# ── AI Quote Generation (Optional) ──────────────────────────
# Use OpenAI, or any OpenAI-compatible API
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini

# ── Frontend Build ───────────────────────────────────────────
VITE_API_BASE_URL=https://smtradeint.com/api
